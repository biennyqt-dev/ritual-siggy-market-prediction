RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
# Canonical protocol address used by the server-side indexer and transaction gate.
SIGGY_RITUAL_CONTRACT_ADDRESS=
# Optional but recommended: makes event aggregation start at deployment.
SIGGY_RITUAL_CONTRACT_DEPLOYMENT_BLOCK=
# Backward-compatible public alias. Prefer SIGGY_RITUAL_CONTRACT_ADDRESS.
NEXT_PUBLIC_SIGGY_CONTRACT=
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Optional live market-generator integrations.
# CoinGecko, DefiLlama, GitHub, GDELT, and the Ritual public RPC adapter work without keys.
X_BEARER_TOKEN=
# Vercel supplies this automatically for protected cron invocations.
CRON_SECRET=
# Browser-local admin studio toggle. It never receives a private key.
NEXT_PUBLIC_ENABLE_MARKET_ADMIN=true

# Deployment only. Keep this in local .env or .env.local and never commit or paste it into chat.
# Accepts 64 hex characters with or without 0x.
PRIVATE_KEY=
