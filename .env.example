RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
# Canonical protocol address used by the server-side indexer and transaction gate.
SIGGY_RITUAL_CONTRACT_ADDRESS=
# Optional but recommended: makes event aggregation start at deployment.
SIGGY_RITUAL_CONTRACT_DEPLOYMENT_BLOCK=
# Backward-compatible public alias. Prefer SIGGY_RITUAL_CONTRACT_ADDRESS.
NEXT_PUBLIC_SIGGY_CONTRACT=
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Deployment only. Keep this in .env.local and never commit or paste it into chat.
PRIVATE_KEY=
